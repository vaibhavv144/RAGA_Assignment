# Firebase web app config — copy to `.env.local` and fill in real values.
# Find these at: Firebase Console → Project Settings → General → Your apps → Web app SDK setup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to bypass Firebase and use the built-in mock auth (good for local dev / demos).
VITE_USE_MOCK_AUTH=true
